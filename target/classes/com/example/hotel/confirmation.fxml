<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
       xmlns:fx="http://javafx.com/fxml/1"
       style="-fx-background-color: linear-gradient(to bottom right, #eef2ff, #f8fafc);">

       <VBox spacing="20" alignment="CENTER"
              maxWidth="420"
              style="-fx-background-color: rgba(255,255,255,0.96);
                 -fx-padding: 30;
                 -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 6);">

              <!-- SUCCESS MESSAGE -->
              <VBox spacing="6" alignment="CENTER">
                     <Label text="Booking Successful"
                            style="-fx-font-size: 22px;
                          -fx-font-weight: 800;
                          -fx-text-fill: #16a34a;" />

                     <Label text="Your room has been booked successfully"
                            style="-fx-font-size: 12px;
                          -fx-text-fill: #64748b;" />
              </VBox>

              <!-- BOOKING ID -->
              <VBox spacing="5" alignment="CENTER"
                     style="-fx-background-color: #f1f5ff;
                     -fx-padding: 15;
                     -fx-background-radius: 12;
                     -fx-border-color: #dbeafe;
                     -fx-border-radius: 12;"
                     prefWidth="300">

                     <Label text="Booking ID"
                            style="-fx-font-size: 11px;
                          -fx-text-fill: #64748b;" />

                     <Label fx:id="bookingIdLabel"
                            text="HB123456"
                            style="-fx-font-size: 18px;
                          -fx-font-weight: 700;
                          -fx-text-fill: #2563eb;" />
              </VBox>

              <!-- ACTION BUTTONS -->
              <HBox spacing="15" alignment="CENTER">

                     <Button text="Back"
                            fx:id="backButton"
                            prefWidth="120"
                            style="-fx-background-color: #e2e8f0;
                           -fx-font-size: 13px;
                           -fx-font-weight: 600;
                           -fx-background-radius: 10;" />

                     <Button text="Proceed"
                            fx:id="proceedButton"
                            prefWidth="140"
                            style="-fx-background-color: linear-gradient(to right, #2563eb, #4f46e5);
                           -fx-text-fill: white;
                           -fx-font-size: 13px;
                           -fx-font-weight: 700;
                           -fx-background-radius: 10;" />

              </HBox>

       </VBox>

</StackPane>