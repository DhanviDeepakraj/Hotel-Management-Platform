<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
       xmlns:fx="http://javafx.com/fxml/1"
       fx:controller="com.example.hotel.SummaryController"
       style="-fx-background-color: linear-gradient(to bottom right, #eef2ff, #f8fafc);">

       <VBox spacing="18" alignment="CENTER"
              maxWidth="600"
              style="-fx-background-color: rgba(255,255,255,0.96);
                 -fx-padding: 25;
                 -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 6);">

              <!-- HEADER -->
              <VBox spacing="3" alignment="CENTER">
                     <Label text="Booking Summary"
                            style="-fx-font-size: 22px;
                          -fx-font-weight: 800;
                          -fx-text-fill: #0f172a;" />

                     <Label text="Review your selections"
                            style="-fx-font-size: 12px;
                          -fx-text-fill: #64748b;" />
              </VBox>

              <!-- BOOKINGS LIST -->
              <VBox spacing="12" fx:id="itemsContainer"
                     prefWidth="520">

              </VBox>

              <Separator />

              <!-- TOTAL -->
              <HBox alignment="CENTER_RIGHT"
                     prefWidth="520">

                     <Label text="Total: ₹0"
                            fx:id="totalLabel"
                            style="-fx-font-size: 18px;
                          -fx-font-weight: 800;
                          -fx-text-fill: #2563eb;" />
              </HBox>

              <!-- BUTTONS -->
              <HBox spacing="15" alignment="CENTER">

                     <Button text="Back"
                            fx:id="backButton"
                            prefWidth="140"
                            style="-fx-background-color: #e2e8f0;
                           -fx-font-size: 13px;
                           -fx-font-weight: 600;
                           -fx-background-radius: 10;" />

                     <Button text="Proceed"
                            fx:id="proceedButton"
                            prefWidth="140"
                            style="-fx-background-color: linear-gradient(to right, #2563eb, #4f46e5);
                           -fx-text-fill: white;
                           -fx-font-size: 13px;
                           -fx-font-weight: 700;
                           -fx-background-radius: 10;" />


              </HBox>

       </VBox>

</StackPane>