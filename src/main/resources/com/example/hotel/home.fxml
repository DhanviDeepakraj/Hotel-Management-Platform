<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.example.hotel.HomeController"
    prefWidth="380"
    prefHeight="500"
    alignment="CENTER"
    spacing="25"
    style="-fx-background-color: #1E3A5F;">

    <padding>
        <Insets top="50" bottom="50" left="30" right="30" />
    </padding>

    <!-- TITLE -->
    <VBox alignment="CENTER" spacing="5">
        <Label text="Welcome to"
            style="-fx-text-fill: white; -fx-font-size: 16px;" />

        <Label text="The Pearl Hotel"
            style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" />
    </VBox>

    <!-- BOOK BUTTON -->
    <Button text="Book a Stay"
        onAction="#handleBookClick"
        prefWidth="200"
        prefHeight="45"
        style="
                -fx-background-color: #2C5282;
                -fx-text-fill: white;
                -fx-font-size: 14px;
                -fx-font-weight: bold;
                -fx-background-radius: 8;
            " />

    <!-- SPACER -->
    <Region VBox.vgrow="ALWAYS" />

    <!-- EXISTING BOOKING TEXT -->
    <Label text="Already have a booking?"
        style="-fx-text-fill: #CBD5E0; -fx-font-size: 13px;" />

    <!-- LOGIN BUTTON -->
    <Button text="Log In"
        onAction="#handleLoginClick"
        prefWidth="200"
        prefHeight="45"
        style="
                -fx-background-color: #4C6EF5;
                -fx-text-fill: white;
                -fx-font-size: 14px;
                -fx-font-weight: bold;
                -fx-background-radius: 8;
            " />

    <Button text="Contact Us"
        onAction="#handleContactClick"
        prefWidth="200"
        prefHeight="45"
        style="
            -fx-background-color: #2C5282;
            -fx-text-fill: white;
            -fx-font-size: 14px;
            -fx-font-weight: bold;
            -fx-background-radius: 10;
        " />

</VBox>