<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
       fx:controller="com.example.hotel.SignupController"
       xmlns:fx="http://javafx.com/fxml/1"
       style="-fx-background-color: linear-gradient(to bottom right, #eef2ff, #f8fafc);">

       <VBox spacing="18" alignment="CENTER"
              maxWidth="420"
              style="-fx-background-color: rgba(255,255,255,0.96);
                 -fx-padding: 25;
                 -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 6);">

              <!-- HEADER -->
              <VBox spacing="3" alignment="CENTER">
                     <Label text="Guest Details"
                            style="-fx-font-size: 22px;
                          -fx-font-weight: 800;
                          -fx-text-fill: #0f172a;" />

                     <Label text="Enter your information"
                            style="-fx-font-size: 12px;
                          -fx-text-fill: #64748b;" />
              </VBox>

              <!-- FORM -->
              <VBox spacing="12" alignment="CENTER_LEFT"
                     prefWidth="320">

                     <!-- NAME -->
                     <VBox spacing="4">
                            <Label text="Full Name"
                                   style="-fx-font-size: 11px; -fx-text-fill: #64748b;" />
                            <TextField fx:id="nameField"
                                   promptText="Enter your name" />
                     </VBox>

                     <!-- DOB -->
                     <VBox spacing="4">
                            <Label text="Date of Birth"
                                   style="-fx-font-size: 11px; -fx-text-fill: #64748b;" />
                            <DatePicker fx:id="dobField" />
                     </VBox>

                     <!-- PHONE -->
                     <VBox spacing="4">
                            <Label text="Phone Number"
                                   style="-fx-font-size: 11px; -fx-text-fill: #64748b;" />
                            <TextField fx:id="phoneField"
                                   promptText="Enter phone number" />
                     </VBox>

                     <!-- ADDRESS -->
                     <VBox spacing="4">
                            <Label text="Address"
                                   style="-fx-font-size: 11px; -fx-text-fill: #64748b;" />
                            <TextArea fx:id="addressField"
                                   promptText="Enter address"
                                   prefRowCount="2" />
                     </VBox>

                     <!-- PASSWORD -->
                     <VBox spacing="4">
                            <Label text="Set Password"
                                   style="-fx-font-size: 11px; -fx-text-fill: #64748b;" />
                            <PasswordField fx:id="passwordField"
                                   promptText="Create password" />
                     </VBox>

              </VBox>
              <!-- CONFIRM PASSWORD -->
              <VBox spacing="4">
                     <Label text="Confirm Password"
                            style="-fx-font-size: 11px; -fx-text-fill: #64748b;" />
                     <PasswordField fx:id="confirmPasswordField"
                            promptText="Re-enter password" />
              </VBox>

              <!-- BUTTONS -->
              <HBox spacing="15" alignment="CENTER">

                     <Button text="Back"
                            fx:id="backButton"
                            prefWidth="120"
                            style="-fx-background-color: #e2e8f0;
                           -fx-font-size: 13px;
                           -fx-font-weight: 600;
                           -fx-background-radius: 10;" />

                     <Button text="Book"
                            fx:id="continueButton"
                            prefWidth="140"
                            style="-fx-background-color: linear-gradient(to right, #2563eb, #4f46e5);
                           -fx-text-fill: white;
                           -fx-font-size: 13px;
                           -fx-font-weight: 700;
                           -fx-background-radius: 10;" />

              </HBox>

       </VBox>

</StackPane>