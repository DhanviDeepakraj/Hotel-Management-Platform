<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
    fx:controller="com.example.hotel.RoomSelectionController"
    xmlns:fx="http://javafx.com/fxml/1"
    style="-fx-background-color: linear-gradient(to bottom right, #eef2ff, #f8fafc);">

    <VBox spacing="18" alignment="CENTER"
        maxWidth="900"
        style="-fx-background-color: rgba(255,255,255,0.96);
                 -fx-padding: 25;
                 -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 6);">

        <!-- HEADER -->
        <VBox spacing="2" alignment="CENTER">
            <Label text="Select Your Room"
                style="-fx-font-size: 24px;
                          -fx-font-weight: 800;
                          -fx-text-fill: #0f172a;" />

            <Label text="Customize your stay with options below"
                style="-fx-font-size: 12px;
                          -fx-text-fill: #64748b;" />
        </VBox>

        <!-- ROOM CARDS -->
        <HBox spacing="20" alignment="CENTER">

            <!-- ================= SINGLE ================= -->
            <StackPane>
                <fx:define>
                    <ToggleGroup fx:id="singleGroup" />
                </fx:define>

                <VBox spacing="10" alignment="TOP_CENTER"
                    prefWidth="260"
                    style="-fx-background-color: linear-gradient(to bottom, #ffffff, #eef2ff);
                             -fx-padding: 16;
                             -fx-background-radius: 14;
                             -fx-border-color: #dbeafe;
                             -fx-border-radius: 14;">

                    <Label text="Single Bed • ₹800/Night"
                        style="-fx-font-size: 15px;
              -fx-font-weight: 700;
              -fx-text-fill: #0f172a;" />

                    <Label fx:id="singleAvailability"
                        text="30 available"
                        style="-fx-font-size: 12px;
              -fx-font-weight: 700;
              -fx-text-fill: #16a34a;" />

                    <VBox spacing="5" alignment="CENTER_LEFT">
                        <Label text="Category"
                            style="-fx-font-size: 10px;
                  -fx-text-fill: #94a3b8;" />


                        <RadioButton fx:id="singleStandard" text="Standard"
                            toggleGroup="$singleGroup" selected="true" />
                        <RadioButton fx:id="singlePremium" text="Premium (+₹600)"
                            toggleGroup="$singleGroup" />
                        <RadioButton fx:id="singleDeluxe" text="Deluxe (+₹1200)"
                            toggleGroup="$singleGroup" />
                    </VBox>

                    <CheckBox fx:id="singleAC"
                        text="AC (+₹500)"
                        style="-fx-font-size: 12px;" />

                    <HBox alignment="CENTER" spacing="5">
                        <Label text="Qty" style="-fx-font-size: 11px;" />
                        <Spinner fx:id="singleSpinner" prefWidth="65" editable="true" />
                    </HBox>

                </VBox>

            </StackPane>

            <!-- ================= DOUBLE ================= -->
            <StackPane>
                <fx:define>
                    <ToggleGroup fx:id="doubleGroup" />
                </fx:define>

                <VBox spacing="10" alignment="TOP_CENTER"
                    prefWidth="260"
                    style="-fx-background-color: linear-gradient(to bottom, #ffffff, #eef2ff);
                 -fx-padding: 16;
                 -fx-background-radius: 14;
                 -fx-border-color: #dbeafe;
                 -fx-border-radius: 14;">

                    <Label text="Double Bed • ₹1200/Night"
                        style="-fx-font-size: 15px;
                      -fx-font-weight: 700;
                      -fx-text-fill: #0f172a;" />

                    <Label fx:id="doubleAvailability"
                        text="40 available"
                        style="-fx-font-size: 12px;
                      -fx-font-weight: 700;
                      -fx-text-fill: #16a34a;" />


                    <!-- ✅ CATEGORY -->
                    <VBox spacing="5" alignment="CENTER_LEFT">
                        <Label text="Category"
                            style="-fx-font-size: 10px;
                          -fx-text-fill: #94a3b8;" />

                        <RadioButton fx:id="doubleStandard" text="Standard"
                            toggleGroup="$doubleGroup" selected="true" />

                        <RadioButton fx:id="doublePremium" text="Premium (+₹600)"
                            toggleGroup="$doubleGroup" />

                        <RadioButton fx:id="doubleDeluxe" text="Deluxe (+₹1200)"
                            toggleGroup="$doubleGroup" />
                    </VBox>

                    <CheckBox fx:id="doubleAC"
                        text="AC (+₹500)"
                        style="-fx-font-size: 12px;" />

                    <HBox alignment="CENTER" spacing="5">
                        <Label text="Qty" style="-fx-font-size: 11px;" />
                        <Spinner fx:id="doubleSpinner" prefWidth="65" editable="true" />
                    </HBox>

                </VBox>

            </StackPane>

            <!-- ================= TRIPLE ================= -->
            <StackPane>
                <fx:define>
                    <ToggleGroup fx:id="tripleGroup" />
                </fx:define>

                <VBox spacing="10" alignment="TOP_CENTER"
                    prefWidth="260"
                    style="-fx-background-color: linear-gradient(to bottom, #ffffff, #eef2ff);
                             -fx-padding: 16;
                             -fx-background-radius: 14;
                             -fx-border-color: #dbeafe;
                             -fx-border-radius: 14;">


                    <Label text="Triple Bed • ₹1800/Night"
                        style="-fx-font-size: 15px;
              -fx-font-weight: 700;
              -fx-text-fill: #0f172a;" />

                    <Label fx:id="tripleAvailability"
                        text="30 available"
                        style="-fx-font-size: 12px;
              -fx-font-weight: 700;
              -fx-text-fill: #16a34a;" />

                    <VBox spacing="5" alignment="CENTER_LEFT">
                        <Label text="Category" />


                        <RadioButton fx:id="tripleStandard" text="Standard"
                            toggleGroup="$tripleGroup" selected="true" />
                        <RadioButton fx:id="triplePremium" text="Premium (+₹600)"
                            toggleGroup="$tripleGroup" />
                        <RadioButton fx:id="tripleDeluxe" text="Deluxe (+₹1200)"
                            toggleGroup="$tripleGroup" />
                    </VBox>


                    <CheckBox fx:id="tripleAC"
                        text="AC (+₹500)"
                        style="-fx-font-size: 12px;" />

                    <HBox alignment="CENTER" spacing="5">
                        <Label text="Qty" style="-fx-font-size: 11px;" />
                        <Spinner fx:id="tripleSpinner" prefWidth="65" editable="true" />
                    </HBox>

                </VBox>

            </StackPane>

        </HBox>
        <!-- ================= STAY DURATION ================= -->
        <!-- ================= STAY DURATION ================= -->
        <VBox spacing="12" alignment="CENTER"
            maxWidth="600"
            style="-fx-background-color: linear-gradient(to bottom, #ffffff, #eef2ff);
             -fx-padding: 18;
             -fx-background-radius: 14;
             -fx-border-color: #dbeafe;
             -fx-border-radius: 14;">

            <Label text="Stay Duration"
                style="-fx-font-size: 16px;
              -fx-font-weight: 700;
              -fx-text-fill: #0f172a;" />

            <HBox spacing="30" alignment="CENTER">

                <!-- FROM -->
                <VBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="From"
                        style="-fx-font-size: 11px;
                          -fx-font-weight: 600;
                          -fx-text-fill: #64748b;" />

                    <DatePicker fx:id="fromDate"
                        prefWidth="180" />
                </VBox>

                <!-- TO -->
                <VBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="To"
                        style="-fx-font-size: 11px;
                          -fx-font-weight: 600;
                          -fx-text-fill: #64748b;" />

                    <DatePicker fx:id="toDate"
                        prefWidth="180" />
                </VBox>

            </HBox>

        </VBox>
        <!-- BUTTONS -->
        <HBox spacing="15" alignment="CENTER">

            <Button fx:id="backButton"
                text="Back"
                prefWidth="150"
                style="-fx-background-color: #e2e8f0;
                           -fx-text-fill: #1e293b;
                           -fx-font-size: 13px;
                           -fx-font-weight: 600;
                           -fx-background-radius: 10;" />

            <Button fx:id="proceedButton"
                onAction="#handleProceed"
                text="Proceed"
                prefWidth="150"
                style="-fx-background-color: linear-gradient(to right, #2563eb, #4f46e5);
                           -fx-text-fill: white;
                           -fx-font-size: 13px;
                           -fx-font-weight: 700;
                           -fx-background-radius: 10;" />

        </HBox>

    </VBox>

</StackPane>